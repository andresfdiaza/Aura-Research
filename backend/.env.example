# ===== Backend runtime =====
NODE_ENV=development
PORT=4000

# ===== Database (Option 1: discrete vars) =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=scraping

# ===== Database (Option 2: single URL) =====
# If DATABASE_URL is set, it takes priority over DB_HOST/DB_USER/etc.
# Example:
# DATABASE_URL=mysql://user:password@host:3306/scraping
DATABASE_URL=

# ===== Optional SSL for managed DBs =====
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ===== Optional pool tuning =====
DB_CONNECTION_LIMIT=10

# URL base del frontend para construir enlaces (password reset, etc.)
FRONTEND_URL=http://localhost:5173

# ===== SMTP (optional) =====
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu_correo@gmail.com
# SMTP_PASS=tu_app_password
# SMTP_FROM="AURA Research <tu_correo@gmail.com>"
